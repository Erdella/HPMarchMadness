# --- Required ---

# Postgres connection string. On Render, this is provided automatically as the
# "Internal Database URL" of the linked Postgres instance.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Secret used to sign session JWTs and hash magic-link tokens.
# Generate with: openssl rand -base64 48
SESSION_SECRET=replace_me_with_a_long_random_string

# Resend API key. Get one free at https://resend.com (100 emails/day free).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Sender address for magic-link emails.
# Use "onboarding@resend.dev" for testing without verifying a domain.
EMAIL_FROM="HP March Madness <onboarding@resend.dev>"

# Comma-separated list of admin email addresses (lowercased).
# Anyone logging in with one of these emails gets admin powers.
ADMIN_EMAILS=jon@sybafargo.com

# Origin allowed by CORS. In production this is your GitHub Pages URL.
# Comma-separated for multiple (e.g. local dev + prod).
FRONTEND_ORIGIN=http://localhost:5173,https://yourname.github.io

# --- Optional ---

# Port to bind. Render sets this automatically. Defaults to 8080 locally.
PORT=8080

# Tournament year used for new entries and results.
TOURNAMENT_YEAR=2026
