# =============================================================================
# HP March Madness — production env for docker-compose
#
# Copy this to `.env` (in the same folder as docker-compose.yml) and fill in
# every value. Keep `.env` out of git — it's already in .gitignore.
# =============================================================================

# --- Postgres -----------------------------------------------------------------
# Database name + user can stay default. Pick a strong password.
POSTGRES_DB=hpmm
POSTGRES_USER=hpmm
POSTGRES_PASSWORD=replace_me_with_a_strong_password

# --- Server -------------------------------------------------------------------

# Random string used to sign session JWTs. Generate with:
#   openssl rand -base64 48
SESSION_SECRET=replace_me_with_at_least_32_random_chars

# Resend API key. Get a free one at https://resend.com (100 emails/day free).
# After adding, verify hpmarchmadness.org as a sending domain so emails come
# from a real address. Until then you can use onboarding@resend.dev.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="HP March Madness <onboarding@resend.dev>"

# Comma-separated lowercased emails of pool admins. Anyone signing in with
# one of these gets admin powers. To rotate, edit this and `docker compose up -d`.
ADMIN_EMAILS=jon@sybafargo.com,brett.henry@live.com

# Comma-separated allowed CORS origins. Include the production frontend URL
# AND any localhost URLs you might use during development.
FRONTEND_ORIGIN=https://hpmarchmadness.org,http://localhost:5173

# Tournament year used for new entries and results.
TOURNAMENT_YEAR=2026

# --- Cloudflare Tunnel --------------------------------------------------------
# Create a tunnel at https://one.dash.cloudflare.com → Networks → Tunnels.
# Click "Create a tunnel" → Cloudflared → name it (e.g. "hp-march-madness")
# → on the install screen, copy the long token shown in the docker command.
# Paste it here. (See DEPLOY.md for screenshots of the steps.)
CLOUDFLARE_TUNNEL_TOKEN=eyJhxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
